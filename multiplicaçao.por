programa {
  funcao inicio() {
    inteiro numero1 
    inteiro numero2
    inteiro resultado

    escreva("digite o primeiro numero: ")
    leia(numero1)

    escreva("digite osegundo número: ")
    leia(numero2)
  
    resultado = numero1 * numero2

    escreva("o resultado da mutiplicaçao é: ", resultado)

 
 }
}
