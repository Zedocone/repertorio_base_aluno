programa {
  funcao inicio() {
    real numero1 
    real numero2
    real resultado

    escreva("digite o primeiro numero: ")
    leia(numero1)

    escreva("digite osegundo número: ")
    leia(numero2)
  
    resultado = numero1 / numero2
  
    escreva("o resultado da divisão é: ", resultado)
  
  
  }

}


